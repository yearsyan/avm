"""The android emulator."""

module(
    name = "android_emulator",
    version = "0.0.1",
)

include("//build/bazel/toolchains:toolchain.MODULE.bazel")

bazel_dep(name = "lz4", version = "1.9.4")
bazel_dep(name = "zlib", version = "1.3.1.bcr.5")
bazel_dep(name = "protobuf", version = "32.1")

# repo_name override needed by @grpc
bazel_dep(name = "protoc-gen-validate", version = "1.2.1.bcr.1", repo_name = "com_envoyproxy_protoc_gen_validate")
bazel_dep(name = "boringssl", version = "0.20250415.0")
bazel_dep(name = "tink_cc", version = "2.4.0")

# Dep of GRPC but override here
# Use local registry version to address https://github.com/bazelbuild/bazel/issues/26922
bazel_dep(name = "c-ares", version = "1.19.1.aemu")
bazel_dep(name = "grpc-java", version = "1.75.0")
bazel_dep(name = "grpc", version = "1.74.1")
single_version_override(
    module_name = "grpc",
    patch_strip = 1,
    patches = [
        "//build/bazel/patch:grpc-no-macos-universal-binary.patch",
        "//build/bazel/patch:grpc_remove_upb-gen.patch",
    ],
)

bazel_dep(name = "abseil-cpp", version = "20250512.1")
bazel_dep(name = "googletest", version = "1.17.0")
bazel_dep(name = "google_benchmark", version = "1.9.4")
bazel_dep(name = "re2", version = "2024-07-02.bcr.1")
bazel_dep(name = "libjpeg_turbo", version = "2.1.91")
bazel_dep(name = "tinyobjloader", version = "2.0.0-rc1.bcr.1")
bazel_dep(name = "pcre2", version = "10.46-DEV")
bazel_dep(name = "glib", version = "2.82.2.bcr.5")
single_version_override(
    module_name = "glib",
    patch_strip = 1,
    patches = [
        "//build/bazel/patch:glib-patches-for-AEMU.patch",
    ],
)

bazel_dep(name = "pkg-config", version = "0.29.2")
bazel_dep(name = "aemu", version = "0.0.1")
local_path_override(
    module_name = "aemu",
    path = "hardware/google/aemu",
)

bazel_dep(name = "qt_prebuilt", version = "6.5.3")
local_path_override(
    module_name = "qt_prebuilt",
    path = "prebuilts/android-emulator-build/qt",
)

bazel_dep(name = "gfxstream", version = "0.0.1")
local_path_override(
    module_name = "gfxstream",
    path = "hardware/google/gfxstream",
)

